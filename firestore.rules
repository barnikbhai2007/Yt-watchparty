// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - User UID
//   - displayName: string (required) - User display name
//   - photoURL: string (optional) - User photo URL
//
// Collection: rooms
// Document ID: {roomId}
// Fields:
//   - videoId: string (required) - YouTube video ID (can be empty)
//   - musicUrl: string (required) - Binimum Music URL (can be empty)
//   - mediaType: string (required) - youtube or music
//   - currentTime: number (required) - Current playback time
//   - isPlaying: bool (required) - Playback state
//   - lastUpdated: timestamp (required) - Last update time
//   - updatedBy: string (required) - UID of the user who updated
//   - name: string (optional) - Room name
//
// Subcollection: rooms/{roomId}/messages
// Fields:
//   - text: string (required) - Chat message text
//   - senderId: string (required) - UID of the sender
//   - senderName: string (required) - Name of the sender
//   - timestamp: timestamp (required) - When the message was sent
//
// Subcollection: rooms/{roomId}/activities
// Fields:
//   - type: string (required) - join, leave, pause, play, seek, change_video
//   - userId: string (required) - UID of the user
//   - userName: string (required) - Name of the user
//   - timestamp: timestamp (required) - When the activity happened
//   - details: string (optional) - Additional details
//
// Subcollection: rooms/{roomId}/participants
// Fields:
//   - uid: string (required) - User UID
//   - displayName: string (required) - User display name
//   - lastSeen: timestamp (required) - Last activity time
//
// Subcollection: rooms/{roomId}/queue
// Fields:
//   - mediaId: string (required) - YouTube video ID or Binimum Music URL
//   - mediaType: string (required) - youtube or music
//   - title: string (required) - Title of the media
//   - addedBy: string (required) - UID of the user who added it
//   - addedByName: string (required) - Name of the user who added it
//   - timestamp: timestamp (required) - When it was added
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "webblogger82@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('lastUpdated' in data) || data.lastUpdated is timestamp) &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidRoom(data) {
      return isAuthenticated();
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['mediaId', 'mediaType', 'timestamp']) &&
             data.mediaId is string &&
             data.mediaType in ['youtube', 'music'] &&
             (!('title' in data) || data.title is string) &&
             (!('thumbnailUrl' in data) || data.thumbnailUrl == null || data.thumbnailUrl is string) &&
             data.timestamp is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             (!('photoURL' in data) || data.photoURL is string) &&
             data.timestamp is timestamp;
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['type', 'userId', 'userName', 'timestamp']) &&
             data.type in ['join', 'leave', 'pause', 'play', 'seek', 'change_video', 'shuffle'] &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             (!('details' in data) || data.details is string) &&
             data.timestamp is timestamp;
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['uid', 'displayName', 'lastSeen']) &&
             data.uid == request.auth.uid &&
             data.displayName is string &&
             (!('photoURL' in data) || data.photoURL is string) &&
             data.lastSeen is timestamp;
    }

    function isValidQueueItemCreate(data) {
      return data.keys().hasAll(['mediaId', 'mediaType', 'title', 'addedBy', 'addedByName', 'timestamp']) &&
             data.mediaId is string &&
             data.mediaType in ['youtube', 'music'] &&
             data.title is string &&
             data.addedBy == request.auth.uid &&
             data.addedByName is string &&
             (!('thumbnailUrl' in data) || data.thumbnailUrl == null || data.thumbnailUrl is string) &&
             data.timestamp is timestamp;
    }

    function isValidQueueItemUpdate(data, resourceData) {
      return data.keys().hasAll(['mediaId', 'mediaType', 'title', 'addedBy', 'addedByName', 'timestamp']) &&
             data.mediaId == resourceData.mediaId &&
             data.mediaType == resourceData.mediaType &&
             data.title == resourceData.title &&
             data.addedBy == resourceData.addedBy &&
             data.addedByName == resourceData.addedByName &&
             (!('thumbnailUrl' in data) || data.thumbnailUrl == null || data.thumbnailUrl is string) &&
             data.timestamp is timestamp;
    }

    function isValidReaction(data) {
      return data.keys().hasAll(['emoji', 'userId', 'timestamp']) &&
             data.emoji is string && data.emoji.size() > 0 && data.emoji.size() < 10 &&
             data.userId == request.auth.uid &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      allow update: if isAuthenticated() && isValidRoom(request.resource.data);
      allow delete: if isAuthenticated();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      }

      match /activities/{activityId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidActivity(request.resource.data);
      }

      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && isValidParticipant(request.resource.data);
        allow delete: if isAuthenticated() && participantId == request.auth.uid;
      }

      match /queue/{queueItemId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidQueueItemCreate(request.resource.data);
        allow update: if isAuthenticated() && isValidQueueItemUpdate(request.resource.data, resource.data);
        allow delete: if isAuthenticated();
      }

      match /history/{historyItemId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidHistoryItem(request.resource.data);
        allow delete: if isAuthenticated();
      }

      match /reactions/{reactionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidReaction(request.resource.data);
      }
    }
  }
}
