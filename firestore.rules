// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - User UID
//   - displayName: string (required) - User display name
//   - photoURL: string (optional) - User photo URL
//
// Collection: rooms
// Document ID: {roomId}
// Fields:
//   - videoId: string (required) - YouTube video ID
//   - currentTime: number (required) - Current playback time
//   - isPlaying: bool (required) - Playback state
//   - lastUpdated: timestamp (required) - Last update time
//   - updatedBy: string (required) - UID of the user who updated
//   - name: string (optional) - Room name
//
// Subcollection: rooms/{roomId}/messages
// Fields:
//   - text: string (required) - Chat message text
//   - senderId: string (required) - UID of the sender
//   - senderName: string (required) - Name of the sender
//   - timestamp: timestamp (required) - When the message was sent
//
// Subcollection: rooms/{roomId}/activities
// Fields:
//   - type: string (required) - join, leave, pause, play, seek, change_video
//   - userId: string (required) - UID of the user
//   - userName: string (required) - Name of the user
//   - timestamp: timestamp (required) - When the activity happened
//   - details: string (optional) - Additional details
//
// Subcollection: rooms/{roomId}/participants
// Fields:
//   - uid: string (required) - User UID
//   - displayName: string (required) - User display name
//   - lastSeen: timestamp (required) - Last activity time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100;
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['videoId', 'currentTime', 'isPlaying', 'lastUpdated', 'updatedBy']) &&
             data.videoId is string && data.videoId.size() > 0 &&
             data.currentTime is number &&
             data.isPlaying is bool &&
             data.lastUpdated is timestamp &&
             data.updatedBy is string && data.updatedBy == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'timestamp']) &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.timestamp is timestamp;
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['type', 'userId', 'userName', 'timestamp']) &&
             data.type in ['join', 'leave', 'pause', 'play', 'seek', 'change_video'] &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.timestamp is timestamp;
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['uid', 'displayName', 'lastSeen']) &&
             data.uid == request.auth.uid &&
             data.displayName is string &&
             data.lastSeen is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      allow update: if isAuthenticated() && isValidRoom(request.resource.data);
      allow delete: if isAuthenticated();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      }

      match /activities/{activityId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidActivity(request.resource.data);
      }

      match /participants/{participantId} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && isValidParticipant(request.resource.data);
        allow delete: if isAuthenticated() && participantId == request.auth.uid;
      }
    }
  }
}
